# Database
DATABASE_URL=postgresql://chorely:chorely@localhost:5432/chorely

# AI Providers (optional — app works without them)
OPENROUTER_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Avatar generation (optional — uses OPENROUTER_API_KEY; override the models if you like)
# AVATAR_MODEL is used when the user picks "Quality" (slower, sharper)
# AVATAR_MODEL_FAST is used when the user picks "Fast" (~5s, lower fidelity)
AVATAR_MODEL=openai/gpt-5.4-image-2
AVATAR_MODEL_FAST=google/gemini-2.5-flash-image

# Mem0 Memory Layer (optional — voice assistant works without it)
MEM0_API_KEY=

# Admin
DEFAULT_ADMIN_PIN=1234

# Voice Providers (optional — only needed if you want ElevenLabs or Bedrock)
ELEVENLABS_API_KEY=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
